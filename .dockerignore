# Git
.git
.gitignore
.gitattributes

# Node (installed inside the node build stage)
node_modules

# PHP vendor (installed fresh by composer in Dockerfile)
vendor

# Built assets (built in the node stage)
public/build
public/hot

# Existing SQLite (generated fresh inside Dockerfile)
database/database.sqlite
database/database.sqlite-wal
database/database.sqlite-shm

