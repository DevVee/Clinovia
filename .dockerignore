.phpunit.result.cache
.phpunit.cache
tests/
phpunit.xml

# Editor / OS
.vscode
.idea
.fleet
.nova
.zed
.DS_Store
Thumbs.db

# Docker compose (local dev only)
docker-compose*.yml
Homestead.*
